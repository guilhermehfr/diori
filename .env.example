# PostgreSQL connection string for Drizzle ORM
DATABASE_URL="postgresql://user:password@host/database"

# Environment variables for the image upload server
# Set to 'false' for production (Vercel), 'true' for local development
DEVELOPMENT_MODE="true"

# Vercel Blob storage token (get from Vercel project settings)
BLOB_READ_WRITE_TOKEN="your_blob_read_write_token_here"

# Vercel Blob storage URL for uploaded images (used primarily for seed when DEVELOPMENT_MODE is 'false')
VERCEL_IMAGE_BLOB_URL="https://your-blob-id.public.blob.vercel-storage.com/uploads"

# Directory where uploaded images will be stored in development
DEVELOPMENT_IMAGE_UPLOAD_DIRECTORY="uploads"

# Complete URL to access the image server in development, without / at the end
DEVELOPMENT_IMAGE_SERVER_URL="http://localhost:3000"

# Environment variables for the image upload
NEXT_PUBLIC_IMAGE_UPLOAD_MAX_SIZE=921600 # 900 KB * 1024 = 921600 bytes

# JWT secret key for signing tokens
JWT_SECRET_KEY="your_secret_key_here"

# Login session expiration time
LOGIN_EXPIRATION_SECONDS=86400 # 24 hours
LOGIN_EXPIRATION_STRING="24h"

# Cookie name for login session
LOGIN_COOKIE_NAME="loginSession"

# Login credentials - Username and Hash password
LOGIN_USERNAME="your_username"
LOGIN_PASSWORD="your_hashed_password" # Create it using the file src/utils/generated-hash-password.ts

# 0 = Login disabled, 1 = Login enabled
ALLOW_LOGIN=0

# This variable is used to enable a showcase mode where authentication is bypassed for demonstration purposes.
SHOWCASE_MODE="false" # Set to "true" to enable showcase mode, which bypasses authentication for demonstration purposes.
